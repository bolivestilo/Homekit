{
  "name": "homekit-mcp",
  "version": "1.1.0",
  "description": "MCP server — give any AI agent direct control over Apple Home",
  "homepage": "https://homekit.builders",
  "repository": {
    "type": "git",
    "url": "https://github.com/bolivestilo/Homekit.git",
    "directory": "packages/mcp"
  },
  "author": "bolivestilo <https://github.com/bolivestilo>",
  "license": "MIT",
  "bin": {
    "homekit-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@homekit/core": "*",
    "zod": "^4.4.3"
  },
  "keywords": [
    "mcp", "homekit", "apple-home", "ai-agent",
