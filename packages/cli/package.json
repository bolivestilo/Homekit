{
  "name": "homekit-cli",
  "version": "1.1.0",
  "description": "Control your Apple Home from the command line",
  "homepage": "https://homekit.builders",
  "repository": {
    "type": "git",
    "url": "https://github.com/bolivestilo/Homekit.git",
    "directory": "packages/cli"
  },
  "author": "bolivestilo <https://github.com/bolivestilo>",
  "license": "MIT",
  "bin": {
    "homekit": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "@homekit/core": "*",
    "commander": "^15.0.0",
    "chalk": "^5.3.0"
  },
  "keywords": ["homekit", "apple-home", "cli", "smart-home", "macos"],
  "engines": { "node": ">=18" }
}
