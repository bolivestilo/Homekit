{
  "name": "@homekit/core",
  "version": "1.1.0",
  "description": "Shared HomeKit bridge, types, and auth manager for the Homekit ecosystem",
  "homepage": "https://homekit.builders",
  "repository": {
    "type": "git",
    "url": "https://github.com/bolivestilo/Homekit.git",
    "directory": "packages/core"
  },
  "author": "bolivestilo <https://github.com/bolivestilo>",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js"
  },
  "keywords": [
    "homekit", "apple-home", "mcp", "smart-home", "typescript"
  ],
  "engines": { "node": ">=18" }
}
