{
  "name": "@openclaw/homekit",
  "version": "1.1.0",
  "description": "@openclaw plugin — give any OpenClaw agent direct control over Apple Home",
  "homepage": "https://homekit.builders",
  "repository": {
    "type": "git",
    "url": "https://github.com/bolivestilo/Homekit.git",
    "directory": "packages/openclaw"
  },
  "author": "bolivestilo <https://github.com/bolivestilo>",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@homekit/core": "*"
  },
  "peerDependencies": {
    "@openclaw/core": ">=1.0.0"
  },
  "keywords": ["openclaw", "homekit", "apple-home", "plugin", "ai-agent"],
  "engines": { "node": ">=18" }
}
